digraph "processor" {
label="processor";
rankdir="LR";
remincross=true;
n1 [ shape=diamond, label="wb_sel", color="black", fontcolor="black"];
n2 [ shape=diamond, label="rw_type", color="black", fontcolor="black"];
n3 [ shape=diamond, label="mem_we", color="black", fontcolor="black"];
n4 [ shape=diamond, label="alu_control", color="black", fontcolor="black"];
n5 [ shape=diamond, label="a_sel", color="black", fontcolor="black"];
n6 [ shape=diamond, label="b_sel", color="black", fontcolor="black"];
n7 [ shape=diamond, label="brlt", color="black", fontcolor="black"];
n8 [ shape=diamond, label="beq", color="black", fontcolor="black"];
n9 [ shape=diamond, label="BrUn", color="black", fontcolor="black"];
n10 [ shape=diamond, label="imm_sel", color="black", fontcolor="black"];
n11 [ shape=diamond, label="reg_we", color="black", fontcolor="black"];
n12 [ shape=diamond, label="instr", color="black", fontcolor="black"];
n13 [ shape=diamond, label="pc_sel", color="black", fontcolor="black"];
n14 [ shape=octagon, label="zero", color="black", fontcolor="black"];
n15 [ shape=octagon, label="reset", color="black", fontcolor="black"];
n16 [ shape=octagon, label="clk", color="black", fontcolor="black"];
c18 [ shape=record, label="{{<p8> beq|<p7> brlt|<p12> instr}|con\ncontroller|{<p9> BrUn|<p5> a_sel|<p17> alucontrol|<p6> b_sel|<p10> imm_sel|<p3> mem_we|<p13> pc_sel|<p11> reg_we|<p2> rw_type|<p1> wb_sel}}",  ];
c20 [ shape=record, label="{{<p9> BrUn|<p5> a_sel|<p4> alu_control|<p6> b_sel|<p16> clk|<p10> imm_sel|<p3> mem_we|<p13> pc_sel|<p11> reg_we|<p15> reset|<p2> rw_type|<p1> wb_sel}|dp\ndata_path|{<p8> beq|<p7> brlt|<p12> instr|<p19> zero_flag}}",  ];
c18:p1:e -> n1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n1:e -> c20:p1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
