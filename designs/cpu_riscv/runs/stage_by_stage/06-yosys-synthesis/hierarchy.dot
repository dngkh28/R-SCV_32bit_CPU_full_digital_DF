c20:p12:e -> n12:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n12:e -> c18:p12:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c18:p13:e -> n13:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n13:e -> c20:p13:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c20:p19:e -> n14:w [color="black", fontcolor="black", label=""];
n15:e -> c20:p15:w [color="black", fontcolor="black", label=""];
n16:e -> c20:p16:w [color="black", fontcolor="black", label=""];
c18:p2:e -> n2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n2:e -> c20:p2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c18:p3:e -> n3:w [color="black", fontcolor="black", label=""];
n3:e -> c20:p3:w [color="black", fontcolor="black", label=""];
c18:p17:e -> n4:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n4:e -> c20:p4:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c18:p5:e -> n5:w [color="black", fontcolor="black", label=""];
n5:e -> c20:p5:w [color="black", fontcolor="black", label=""];
c18:p6:e -> n6:w [color="black", fontcolor="black", label=""];
n6:e -> c20:p6:w [color="black", fontcolor="black", label=""];
c20:p7:e -> n7:w [color="black", fontcolor="black", label=""];
n7:e -> c18:p7:w [color="black", fontcolor="black", label=""];
c20:p8:e -> n8:w [color="black", fontcolor="black", label=""];
