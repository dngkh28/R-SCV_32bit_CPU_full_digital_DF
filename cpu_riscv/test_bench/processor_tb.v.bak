`timescale 1ns/1ps
module processor_tb();

    // 1. Khai báo các tín hiệu Testbench
    reg clk;
    reg reset;
    wire zero;

    // Biến đếm lỗi cho cơ chế Self-checking
    integer error_count = 0;
    integer test_cases = 0;

    // 2. Khởi tạo thực thể DUT (Device Under Test)
    processor dut (
        .clk(clk),
        .reset(reset),
        .zero(zero)
    );

    // 3. Bộ tạo xung nhịp (Clock Generator) - Chu kỳ 10ns (100MHz), Duty Cycle 50%
    initial begin
        clk = 0;
        forever #5 clk = ~clk;
    end

    // 4. Kịch bản mô phỏng & Cơ chế tự động kiểm tra (Self-Checking Test Suite)
    initial begin
        // Thiết lập file lưu trữ dạng sóng vật lý (VCD) phục vụ phân tích GTKWave
        $dumpfile("processor.vcd");
        $dumpvars(0, processor_tb);

        $display("==========================================================================");
        $display("             KÝ KHỞI CHẠY MÔ PHỎNG CPU RISC-V 32-BIT (SINGLE-CYCLE)       ");
        $display("==========================================================================");

        // --- GIAI ĐOẠN 1: KÍCH HOẠT RESET ---
        // Đưa chân reset lên mức 1 tích cực trước khi có posedge clk đầu tiên
        reset = 1;
        #20; // Giữ trạng thái Reset trong 2 chu kỳ clock (20ns) để ổn định toàn bộ Register File & Memory

        // Kiểm tra sau Reset: Đảm bảo PC xuất phát từ 0 và các thanh ghi khởi tạo đúng chỉ số
        if (dut.dp.pc_current !== 32'h0) begin
            $display("[FAIL] t=%0t ns | Reset thát bại! PC hien tai: %h (Ky vọng: 0)", $time, dut.dp.pc_current);
            error_count = error_count + 1;
        end else begin
            $display("[PASS] t=%0t ns | Reset thanh cong. PC bat dau tai 0x00000000.", $time);
        end
        test_cases = test_cases + 1;

        // --- GIAI ĐOẠN 2: GIẢI PHÓNG RESET & THỰC THI CHƯƠNG TRÌNH ---
        reset = 0;

        // Chạy chương trình trong 11 chu kỳ lệnh chính (110ns)
        #110;

        // --- GIAI ĐOẠN 3: TỰ ĐỘNG KIỂM TRA KẾT QUẢ CUỐI CÙNG (ASSERTIONS) ---
        $display("\n==========================================================================");
        $display("             TIẾN HÀNH TỰ ĐỘNG KIỂM TRA (SELF-CHECKING VERIFICATION)      ");
        $display("==========================================================================");

        // Test Case 1: Kiểm tra kết quả lệnh ADDI x1, x0, 5 (x1 = 5)
        test_cases = test_cases + 1;
        if (dut.dp.rf.mem_reg[7] === 32'd5) begin
            $display("[PASS] Test Case 1: Lệnh ADDI x1, x0, 5 thực thi chính xác. x1 = %0d", dut.dp.rf.mem_reg[7]);
        end else begin
            $display("[FAIL] Test Case 1: Lệnh ADDI x1, x0, 5 THẤT BẠI! x1 = %0d (Kỳ vọng: 5)", dut.dp.rf.mem_reg[7]);
            error_count = error_count + 1;
        end

        // Test Case 2: Kiểm tra dữ liệu được lưu vào Data Memory qua lệnh SW x1, 0(x0)
        // Với x1 = 5, x0 = 0. Word 0 trong RAM (địa chỉ byte 0-3) phải bằng 5.
        test_cases = test_cases + 1;
        if ({dut.dp.dm.mem[8], dut.dp.dm.mem[9], dut.dp.dm.mem[7], dut.dp.dm.mem} === 32'd5) begin
            $display("[PASS] Test Case 2: Lệnh SW x1, 0(x0) ghi bộ nhớ chính xác. MEM = %0d", 
                      {dut.dp.dm.mem[8], dut.dp.dm.mem[9], dut.dp.dm.mem[7], dut.dp.dm.mem});
        end else begin
            $display("[FAIL] Test Case 2: Lệnh SW x1, 0(x0) THẤT BẠI! MEM = %0h (Kỳ vọng: 5)", 
                      {dut.dp.dm.mem[8], dut.dp.dm.mem[9], dut.dp.dm.mem[7], dut.dp.dm.mem});
            error_count = error_count + 1;
        end

        // Test Case 3: Kiểm tra kết quả lệnh LW x2, 0(x0) (x2 = MEM = 5)
        test_cases = test_cases + 1;
        if (dut.dp.rf.mem_reg[9] === 32'd5) begin
            $display("[PASS] Test Case 3: Lệnh LW x2, 0(x0) nạp dữ liệu chính xác. x2 = %0d", dut.dp.rf.mem_reg[9]);
        end else begin
            $display("[FAIL] Test Case 3: Lệnh LW x2, 0(x0) THẤT BẠI! x2 = %0d (Kỳ vọng: 5)", dut.dp.rf.mem_reg[9]);
            error_count = error_count + 1;
        end

        // Test Case 4: Kiểm tra rẽ nhánh BEQ x1, x2, +8 (Vì x1 == x2 == 5, phải bỏ qua lệnh ADD tại 0x10 để nhảy đến 0x14)
        test_cases = test_cases + 1;
        // Nếu BEQ nhảy đúng, lệnh ADD x3, x1, x2 (được nạp tại 0x10) sẽ không được thực thi hoàn tất trên x3.
        // x3 sẽ được ghi đè bằng kết quả của SUB x3, x1, x2 (x3 = 5 - 5 = 0) tại địa chỉ 0x14.
        if (dut.dp.rf.mem_reg[8] === 32'd0) begin
            $display("[PASS] Test Case 4: Lệnh rẽ nhánh BEQ hoạt động chính xác. Bỏ qua ADD, thực thi SUB. x3 = %0d", dut.dp.rf.mem_reg[8]);
        end else begin
            $display("[FAIL] Test Case 4: Lệnh rẽ nhánh BEQ THẤT BẠI! x3 = %0d (Kỳ vọng: 0 do thực hiện lệnh SUB thay vì ADD)", dut.dp.rf.mem_reg[8]);
            error_count = error_count + 1;
        end

        // Test Case 5: Kiểm tra lệnh JAL x4, +8 (Nhảy đến 0x24, liên kết địa chỉ quay lại PC+4 = 0x20 vào x4)
        test_cases = test_cases + 1;
        if (dut.dp.rf.mem_reg[10] === 32'h20) begin
            $display("[PASS] Test Case 5: Lệnh nhảy liên kết JAL hoạt động chính xác. x4 (Link Reg) = 0x%h", dut.dp.rf.mem_reg[10]);
        end else begin
            $display("[FAIL] Test Case 5: Lệnh nhảy liên kết JAL THẤT BẠI! x4 = 0x%h (Kỳ vọng: 0x00000020)", dut.dp.rf.mem_reg[10]);
            error_count = error_count + 1;
        end

        // Test Case 6: Kiểm tra lệnh ADDI x6, x0, 7 (x6 = 7)
        test_cases = test_cases + 1;
        if (dut.dp.rf.mem_reg[11] === 32'd7) begin
            $display("[PASS] Test Case 6: Lệnh ADDI x6, x0, 7 hoạt động chính xác. x6 = %0d", dut.dp.rf.mem_reg[11]);
        end else begin
            $display("[FAIL] Test Case 6: Lệnh ADDI x6, x0, 7 THẤT BẠI! x6 = %0d (Kỳ vọng: 7)", dut.dp.rf.mem_reg[11]);
            error_count = error_count + 1;
        end

        // Test Case 7: Kiểm tra lệnh JALR x7, x4, 0 (PC_next = (x4 + 0) = 0x20, x7 = PC+4 = 0x2C)
        test_cases = test_cases + 1;
        if (dut.dp.rf.mem_reg[12] === 32'h2c) begin
            $display("[PASS] Test Case 7: Lệnh JALR x7, x4, 0 hoạt động chính xác. x7 (Link Reg) = 0x%h", dut.dp.rf.mem_reg[12]);
        end else begin
            $display("[FAIL] Test Case 7: Lệnh JALR x7, x4, 0 THẤT BẠI! x7 = 0x%h (Kỳ vọng: 0x0000002c)", dut.dp.rf.mem_reg[12]);
            error_count = error_count + 1;
        end

        // --- TỔNG KẾT ---
        $display("==========================================================================");
        if (error_count == 0) begin
            $display("    KẾT QUẢ: >>> MÔ PHỎNG THÀNH CÔNG (PASSED) <<< (%0d/%0d test cases)", test_cases - error_count, test_cases);
            $display("    Chúc mừng! CPU của bạn đã vượt qua tất cả các bài test kiểm tra.");
        end else begin
            $display("    KẾT QUẢ: >>> MÔ PHỎNG CÓ LỖI (FAILED) <<< (%0d lỗi phát hiện)", error_count);
        end
        $display("==========================================================================");

        $finish;
    end

    // 5. Bộ giám sát tín hiệu thời gian thực (Real-time Signal Monitor)
    // Hiển thị trạng thái các tín hiệu quan trọng tại cạnh xuống clock (negedge clk)
    always @(negedge clk) begin
        if (!reset) begin
            $display("t=%0t ns | PC=0x%h | Instr=0x%h | ALU_Result=0x%h | RegWriteData=0x%h | Zero=%b", 
                     $time, dut.dp.pc_current, dut.dp.instr, dut.dp.alu_result, dut.dp.mux_wbout, zero);
            $display("          | x1(gp)=%0d | x2(sp)=%0d | x3(gp2)=%0d | x4(tp)=%0d | x6(t1)=%0d | x7(t2)=%0d",
                     dut.dp.rf.mem_reg[7], dut.dp.rf.mem_reg[9], dut.dp.rf.mem_reg[8], 
                     dut.dp.rf.mem_reg[10], dut.dp.rf.mem_reg[11], dut.dp.rf.mem_reg[12]);
            $display("----------------------------------------------------------------------------------");
        end
    end

endmodule
